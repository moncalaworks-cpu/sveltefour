{
	"name": "sveltefour",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "node scripts/verify-no-drafts.js && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"verify:no-drafts": "node scripts/verify-no-drafts.js",
		"content:draft": "node scripts/generate-draft.js",
		"content:publish": "node scripts/publish-drafts.js",
		"backup:docs": "node scripts/backup-docs.js",
		"backup:docs:upload": "node scripts/backup-upload.js",
		"backup:notify": "node scripts/notify-backup-complete.js"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/typography": "^0.5.19",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.8.0",
		"@types/uuid": "^10.0.0",
		"@vitest/coverage-v8": "^4.1.6",
		"@vitest/ui": "^4.1.6",
		"archiver": "^7.0.1",
		"autoprefixer": "^10.5.0",
		"jsdom": "^29.1.1",
		"postcss": "^8.5.14",
		"sharp": "^0.34.5",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^3.4.19",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vitest": "^4.1.6"
	},
	"dependencies": {
		"@vercel/analytics": "^2.0.1",
		"@vercel/speed-insights": "^2.0.0",
		"gray-matter": "^4.0.3",
		"marked": "^18.0.3",
		"pdfkit": "^0.18.0",
		"uuid": "^14.0.0"
	}
}
